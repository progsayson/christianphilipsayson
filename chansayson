    </p>
    <div class="hero-actions">
      <a href="#projects" class="btn-primary">View my work</a>
      <a href="#contact" class="btn-secondary">Get in touch</a>
    </div>
    <div class="hero-scroll">
      <span class="scroll-line"></span>
      scroll to explore
    </div>
  </div>

  <!-- ABOUT -->
  <section id="about">
