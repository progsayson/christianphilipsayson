        </div>
      </div>

    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="contact-inner">
      <div class="section-label" style="text-align:center">04 — Contact</div>
      <h2>Let's build something</h2>
      <p>Have a project in mind or want to collaborate? I'd love to hear from you.</p>
      <div class="contact-links">
        <a href="mailto:you@email.com" class="btn-primary">Send me an email</a>
        <a href="https://github.com/yourusername" target="_blank" class="btn-secondary">GitHub</a>
        <a href="https://linkedin.com/in/yourusername" target="_blank" class="btn-secondary">LinkedIn</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <span>// yourname.dev</span>
    <span>Designed & built with care · 2024</span>
  </footer>

  <script>
    // Scroll fade-in
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
  </script>
</body>
</html>
