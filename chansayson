    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects">
    <div class="section-label">03 — Projects</div>
    <h2>Selected work</h2>
    <p class="section-intro">Things I've built that I'm proud of.</p>
    <div class="projects-grid">

      <div class="project-card fade-up">
        <div class="project-tag">Full-stack · 2024</div>
